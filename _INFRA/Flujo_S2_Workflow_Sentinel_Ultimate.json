        "fileName": "=/data/agencia/backups/dlq/sentinel_dlq.jsonl",
        "fileContent": "={{ JSON.stringify($json) }}\n"
      },
      "id": "dlq-file-01",
      "name": "DLQFile",
      "type": "n8n-nodes-base.readWriteFile",
      "typeVersion": 1,
      "position": [480, 600],
