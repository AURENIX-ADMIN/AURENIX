    {
      "parameters": {},
      "id": "err-internal-01",
      "name": "ErrorTriggerS2Internal",
      "type": "n8n-nodes-base.errorTrigger",
      "typeVersion": 1,
      "position": [0, 600]
    },
    {
      "parameters": {
        "jsCode": "// DLQ: Si S2 falla internamente, guardar el error raw para reprocesar\nconst raw = JSON.stringify($json);\nconst dlqEntry = {\n  timestamp: new Date().toISOString(),\n  source: 'S2_INTERNAL_FAILURE',\n  raw_payload: raw.substring(0, 5000)\n};\nreturn [{ json: dlqEntry }];"
      },
      "id": "dlq-01",
      "name": "DLQWrite",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [240, 600]
    },
    {
