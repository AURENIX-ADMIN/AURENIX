      "parameters": {
        "chatId": "501092522",
        "text": "=\ud83d\udc80 *S2 SENTINEL \u2014 FALLO INTERNO*\n\nEl propio Sentinel ha fallado. Error guardado en DLQ.\n*Error:* {{ $json.raw_payload ? $json.raw_payload.substring(0, 500) : 'Ver DLQ' }}\n\nRevisa `/data/agencia/backups/dlq/sentinel_dlq.jsonl`",
        "additionalFields": { "parse_mode": "Markdown" }
      },
      "id": "tel-dlq-01",
      "name": "TelegramDLQAlert",
