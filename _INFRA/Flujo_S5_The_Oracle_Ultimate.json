    {
      "parameters": {
        "modelName": "llama3-8b-8192",
        "options": { "temperature": 0.1 }
      },
      "id": "groq-8b-01",
      "name": "GroqLlama3-8B",
      "type": "@n8n/n8n-nodes-langchain.lmChatGroq",
      "typeVersion": 1,
      "position": [1000, 420],
      "credentials": {
        "groqApi": { "id": "3xX3Du0zMIty4shQ", "name": "Groq account" }
      }
    },
    {
      "parameters": {
        "jsCode": "// Parse triage response con fallback (multi-score V2)\ntry {\n  let raw = $input.first().json.text;\n  if (raw.includes('```json')) raw = raw.replace(/```json\\n?/g, '').replace(/```\\n?/g, '');\n  else if (raw.includes('```')) raw = raw.replace(/```\\n?/g, '');\n  \n  const evaluation = JSON.parse(raw.trim());\n  const original = $input.first().json;\n  return [{ json: { \n    title: original.title || 'Sin titulo',\n    link: original.link || '',\n    contentSnippet: original.contentSnippet || '',\n    ai_relevance: evaluation.ai_relevance || 0,\n    investment_relevance: evaluation.investment_relevance || 0,\n    security_relevance: evaluation.security_relevance || 0,\n    overall_score: evaluation.overall_score || 0,\n    score: evaluation.overall_score || 0,\n    relevant: evaluation.relevant || false, \n    reason: evaluation.reason || 'Sin razon',\n    tags: evaluation.tags || [],\n    category: evaluation.category || 'tech'\n  }}];\n} catch (e) {\n  return [{ json: { \n    title: $input.first().json.title || 'Sin titulo',\n    link: $input.first().json.link || '',\n    ai_relevance: 0, investment_relevance: 0, security_relevance: 0,\n    overall_score: 0, score: 0, \n    relevant: false, \n    reason: 'Error parsing triage: ' + e.message,\n    tags: [], category: 'tech'\n  }}];\n}"
      },
      "id": "parse-triage-01",
      "name": "ParseTriageResult",
