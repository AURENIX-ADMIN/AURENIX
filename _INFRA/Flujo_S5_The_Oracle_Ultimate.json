        "jsCode": "// Fallback si Jina fallo: usar snippet original\nconst jinaData = $input.first().json;\nconst triageData = $('ParseTriageResult').first().json;\n\nconst content = jinaData.data || jinaData.content || jinaData.text || triageData.contentSnippet || 'Contenido no disponible';\n\nreturn [{ json: { \n  title: triageData.title,\n  content: typeof content === 'string' ? content.substring(0, 8000) : JSON.stringify(content).substring(0, 8000),\n  link: triageData.link,\n  score: triageData.overall_score || triageData.score,\n  ai_relevance: triageData.ai_relevance || 0,\n  investment_relevance: triageData.investment_relevance || 0,\n  security_relevance: triageData.security_relevance || 0,\n  overall_score: triageData.overall_score || 0,\n  category: triageData.category || 'tech',\n  tags: triageData.tags\n}}];"
