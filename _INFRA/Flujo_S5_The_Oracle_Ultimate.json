    {
      "parameters": {
        "jsCode": "// Collect ALL items from all 12 RSS feeds, dedup by title, limit 50\nconst items = $input.all();\nconst seen = new Set();\nconst unique = [];\n\nfor (const item of items) {\n  const title = (item.json.title || '').trim().toLowerCase();\n  if (!title || seen.has(title)) continue;\n  seen.add(title);\n  unique.push(item);\n}\n\nif (unique.length === 0) {\n  return [{ json: { _empty: true, title: 'No items from any feed', link: '', contentSnippet: '' } }];\n}\n\nreturn unique.slice(0, 50);"
      },
      "id": "dedup-01",
      "name": "DedupLimit30",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [520, 280],
      "onError": "continueErrorOutput"
    },
