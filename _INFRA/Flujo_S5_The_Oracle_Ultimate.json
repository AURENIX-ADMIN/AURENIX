        "jsCode": "// Daily Summary — fires ONCE after all items processed\n// Count stats from this execution\nconst staticData = $getWorkflowStaticData('global');\nconst today = new Date().toISOString().split('T')[0];\n\n// Track daily stats\nif (!staticData.dailyStats || staticData.dailyStats.date !== today) {\n  staticData.dailyStats = { date: today, total: 0, relevant: 0 };\n}\nstaticData.dailyStats.total++;\n\nconst isRelevant = $json.relevant || false;\nif (!isRelevant) {\n  // Non-relevant item — increment counter but don't send summary yet\n  // Summary will be sent by the cron schedule at end of pipeline\n}\n\nreturn [{ json: { \n  total: staticData.dailyStats.total, \n  relevant: staticData.dailyStats.relevant,\n  date: today\n}}];"
      },
