# ─── SERVIDOR ────────────────────────────────────────────────
PORT=8003
ENVIRONMENT=production
# Generar con: openssl rand -hex 64
SECRET_KEY=CHANGE_ME_64_HEX_CHARS
ALLOWED_HOSTS=orbit.aurenix.cloud

# ─── BASE DE DATOS ───────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://orbit_user:CHANGE_ME@localhost:5432/orbit_db

# ─── AUTENTICACION JWT ───────────────────────────────────────
# Generar con: openssl rand -hex 64 (diferente de SECRET_KEY)
JWT_SECRET_KEY=CHANGE_ME_DIFFERENT_64_HEX_CHARS
JWT_ALGORITHM=HS256
JWT_EXPIRE_HOURS=8

# ─── RATE LIMITING ───────────────────────────────────────────
RATE_LIMIT_LOGIN=10/5minutes
RATE_LIMIT_API=200/minute

# ─── TELEGRAM (alertas internas AURENIX) ─────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_ADMIN_CHAT_ID=

# ─── PULL DE METRICAS ────────────────────────────────────────
METRICS_PULL_INTERVAL_MINUTES=60
METRICS_PULL_TIMEOUT_SECONDS=10
HEARTBEAT_ALERT_AFTER_MINUTES=10

# ─── ALERTAS ─────────────────────────────────────────────────
ALERT_CPU_THRESHOLD_PCT=85
ALERT_RAM_THRESHOLD_PCT=90
ALERT_DISK_THRESHOLD_PCT=80
ALERT_CLAUDE_COST_MONTHLY_EUR=50.0

# ─── API INTERNA (n8n / machine-to-machine) ──────────────────
# Generar con: openssl rand -hex 32
INTERNAL_API_KEY=CHANGE_ME_32_HEX_CHARS

# ─── N8N (instancia AURENIX) ─────────────────────────────────
N8N_BASE_URL=http://localhost:5678
N8N_API_KEY=

# ─── HOSTINGER VPS API ───────────────────────────────────────
# Obtener en: hPanel → My profile → API tokens → Create new token
HOSTINGER_API_TOKEN=
# ID del VPS principal (ver en hPanel URL o GET /vps/virtual-machines)
HOSTINGER_VPS_ID=1285851

# ─── ADMIN (primer usuario, cambiar tras primer login) ───────
ADMIN_EMAIL=admin@aurenix.es
ADMIN_PASSWORD=CHANGE_ME_STRONG_PASSWORD
